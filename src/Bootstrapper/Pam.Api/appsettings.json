{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "MassTransit": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "serverUrl": "http://localhost:5341" }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName" ]
  },
  "ConnectionStrings": {
    "Pam": "Host=localhost;Port=5432;Database=pam;Username=pam;Password=pam_dev_password",
    "Redis": "localhost:6379,password=redis_dev_password"
  },
  "MessageBroker": {
    "Host": "localhost",
    "VirtualHost": "/",
    "Username": "pam",
    "Password": "rabbit_dev_password"
  },
  "Identity": {
    "BackOfficeSpa": {
      "ClientId": "pam-bo",
      "DisplayName": "PAM Back-Office SPA",
      "LoginUrl": "http://localhost:3000/login",
      "RedirectUris": [ "http://localhost:3000/auth/callback" ],
      "PostLogoutRedirectUris": [ "http://localhost:3000/" ]
    }
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000" ]
  },
  "AllowedHosts": "*"
}
