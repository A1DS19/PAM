{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "MassTransit": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "serverUrl": "http://localhost:5341" }
      },
      {
        "Name": "OpenTelemetry",
        "Args": {
          "Endpoint": "http://localhost:4317",
          "Protocol": "Grpc",
          "ResourceAttributes": {
            "service.name": "pam-api"
          }
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName" ]
  },
  "ConnectionStrings": {
    "Pam": "Host=localhost;Port=5432;Database=pam;Username=pam;Password=pam_dev_password",
    "Redis": "localhost:6379,password=redis_dev_password"
  },
  "MessageBroker": {
    "Host": "localhost",
    "VirtualHost": "/",
    "Username": "pam",
    "Password": "rabbit_dev_password"
  },
  "Identity": {
    "BackOfficeSpa": {
      "ClientId": "pam-bo",
      "DisplayName": "PAM Back-Office SPA",
      "LoginUrl": "http://localhost:3000/login",
      "ResetPasswordUrl": "http://localhost:3000/reset-password",
      "ConfirmEmailUrl": "http://localhost:3000/confirm-email",
      "RedirectUris": [ "http://localhost:3000/auth/callback" ],
      "PostLogoutRedirectUris": [ "http://localhost:3000/" ]
    }
  },
  "Notifications": {
    "Smtp": {
      "Host": "localhost",
      "Port": 1025,
      "UseStartTls": false,
      "FromAddress": "no-reply@pam.local",
      "FromName": "PAM"
    }
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000" ]
  },
  "DataProtection": {
    "ApplicationName": null
  },
  "OpenIddict": {
    "EncryptionCertificate": {
      "Path": null,
      "Password": null
    },
    "SigningCertificate": {
      "Path": null,
      "Password": null
    }
  },
  "AllowedHosts": "*"
}
