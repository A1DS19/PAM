{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "MassTransit": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": { "serverUrl": "http://localhost:5341" }
      },
      {
        "Name": "OpenTelemetry",
        "Args": {
          "Endpoint": "http://localhost:4317",
          "Protocol": "Grpc",
          "ResourceAttributes": {
            "service.name": "pam-api"
          }
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName"]
  },
  "ConnectionStrings": {
    "Pam": "Server=localhost,1433;Database=pam;User Id=sa;Password=Pam_dev_password_123!;TrustServerCertificate=True;Encrypt=False",
    "Redis": "localhost:6379,password=redis_dev_password"
  },
  "MessageBroker": {
    "Host": "localhost",
    "VirtualHost": "/",
    "Username": "pam",
    "Password": "rabbit_dev_password"
  },
  "Messaging": {
    "Reconciliation": {
      "Interval": "00:05:00",
      "MinAge": "00:02:00",
      "LookbackWindow": "2.00:00:00",
      "RetentionWindow": "3.00:00:00",
      "CleanupBatchSize": 10000,
      "CleanupMaxBatchesPerCycle": 50,
      "Enabled": true
    },
    "Outbox": {
      "MessageDeliveryLimit": 1000,
      "MessageDeliveryTimeout": "00:00:30",
      "QueryDelay": "00:01:00",
      "DuplicateDetectionWindow": "00:30:00"
    }
  },
  "Ingest": {
    "Reconciliation": {
      "ScanBatchSize": 2000,
      "MaxScanBatchesPerCycle": 20
    },
    "Vendors": {
      "FastSpin": {
        "UpstreamUrl": "https://dev-gbs-api-dbdev.lucky99.eu/api/fastspin/main",
        "TimeoutSeconds": 30
      }
    }
  },
  "Identity": {
    "BackOfficeSpa": {
      "ClientId": "pam-bo",
      "DisplayName": "PAM Back-Office SPA",
      "LoginUrl": "http://localhost:3000/login",
      "ResetPasswordUrl": "http://localhost:3000/reset-password",
      "ConfirmEmailUrl": "http://localhost:3000/confirm-email",
      "RedirectUris": ["http://localhost:3000/auth/callback"],
      "PostLogoutRedirectUris": ["http://localhost:3000/"]
    }
  },
  "Notifications": {
    "Smtp": {
      "Host": "localhost",
      "Port": 1025,
      "UseStartTls": false,
      "FromAddress": "no-reply@pam.local",
      "FromName": "PAM"
    }
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:3000"]
  },
  "DataProtection": {
    "ApplicationName": null
  },
  "OpenIddict": {
    "EncryptionCertificate": {
      "Path": null,
      "Password": null
    },
    "SigningCertificate": {
      "Path": null,
      "Password": null
    }
  },
  "AllowedHosts": "*"
}
